# ── BASE DE DONNÉES ──────────────────────────────────────────
DATABASE_URL=postgresql://plm_admin:PASSWORD@HOST:5432/plm_fashion

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=changez_ce_secret_en_production_minimum_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ── SERVEUR ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── UPLOAD FICHIERS ──────────────────────────────────────────
MAX_FILE_SIZE_MB=20
UPLOAD_PATH=./uploads

# ── EMAIL (SMTP) ─────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@plm-fashion.com
